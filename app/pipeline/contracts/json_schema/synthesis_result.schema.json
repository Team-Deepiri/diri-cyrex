{
  "$defs": {
    "Citation": {
      "additionalProperties": false,
      "description": "A verbatim quote from a source document with provenance.",
      "properties": {
        "citation_id": {
          "title": "Citation Id",
          "type": "string"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "document_id": {
          "title": "Document Id",
          "type": "string"
        },
        "extraction_pass": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extraction Pass"
        },
        "locator": {
          "$ref": "#/$defs/CitationLocator"
        },
        "quote": {
          "description": "Verbatim quote, max 500 chars",
          "maxLength": 500,
          "title": "Quote",
          "type": "string"
        },
        "source_doc_hash": {
          "title": "Source Doc Hash",
          "type": "string"
        }
      },
      "required": [
        "document_id",
        "source_doc_hash",
        "locator",
        "quote",
        "confidence"
      ],
      "title": "Citation",
      "type": "object"
    },
    "CitationLocator": {
      "additionalProperties": false,
      "description": "Location within a source document where a quote was found.",
      "properties": {
        "char_end": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Char End"
        },
        "char_start": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Char Start"
        },
        "element_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Element Id"
        },
        "locator_type": {
          "enum": [
            "char_range",
            "page_range",
            "element_id"
          ],
          "title": "Locator Type",
          "type": "string"
        },
        "page_end": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page End"
        },
        "page_start": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Page Start"
        }
      },
      "required": [
        "locator_type"
      ],
      "title": "CitationLocator",
      "type": "object"
    },
    "CitedField": {
      "additionalProperties": false,
      "description": "A single extracted field backed by citations.",
      "properties": {
        "citations": {
          "items": {
            "$ref": "#/$defs/Citation"
          },
          "title": "Citations",
          "type": "array"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "field_name": {
          "title": "Field Name",
          "type": "string"
        },
        "referenced_by": {
          "description": "artifact_ids referencing this field",
          "items": {
            "type": "string"
          },
          "title": "Referenced By",
          "type": "array"
        },
        "references": {
          "description": "artifact_ids this field references",
          "items": {
            "type": "string"
          },
          "title": "References",
          "type": "array"
        },
        "value": {
          "title": "Value"
        },
        "value_type": {
          "default": "string",
          "title": "Value Type",
          "type": "string"
        }
      },
      "required": [
        "field_name",
        "value",
        "confidence"
      ],
      "title": "CitedField",
      "type": "object"
    },
    "ExtractionMethod": {
      "description": "Methods by which a field was extracted.",
      "enum": [
        "regex",
        "llm",
        "cross_ref",
        "pattern",
        "vision"
      ],
      "title": "ExtractionMethod",
      "type": "string"
    },
    "FieldDiscrepancy": {
      "additionalProperties": false,
      "description": "Disagreement between passes or agents on a single field.",
      "properties": {
        "agent_a_confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent A Confidence"
        },
        "agent_a_value": {
          "default": null,
          "title": "Agent A Value"
        },
        "agent_b_confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent B Confidence"
        },
        "agent_b_value": {
          "default": null,
          "title": "Agent B Value"
        },
        "confidence_delta": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence Delta"
        },
        "field_name": {
          "title": "Field Name",
          "type": "string"
        },
        "pass_a_value": {
          "default": null,
          "title": "Pass A Value"
        },
        "pass_b_value": {
          "default": null,
          "title": "Pass B Value"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        }
      },
      "required": [
        "field_name"
      ],
      "title": "FieldDiscrepancy",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "description": "Provenance metadata for an artifact bundle.",
      "properties": {
        "cross_references": {
          "items": {
            "type": "string"
          },
          "title": "Cross References",
          "type": "array"
        },
        "depended_on_by": {
          "items": {
            "type": "string"
          },
          "title": "Depended On By",
          "type": "array"
        },
        "depends_on": {
          "items": {
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        },
        "document_id": {
          "title": "Document Id",
          "type": "string"
        },
        "model_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Id"
        },
        "passes": {
          "items": {
            "$ref": "#/$defs/ProvenancePass"
          },
          "title": "Passes",
          "type": "array"
        },
        "source_doc_hash": {
          "title": "Source Doc Hash",
          "type": "string"
        },
        "synthesized_from": {
          "items": {
            "type": "string"
          },
          "title": "Synthesized From",
          "type": "array"
        },
        "version": {
          "default": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "source_doc_hash",
        "document_id"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "ProvenancePass": {
      "additionalProperties": false,
      "description": "A single extraction pass with metadata.",
      "properties": {
        "extraction_time_ms": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Extraction Time Ms"
        },
        "fields_extracted": {
          "items": {
            "type": "string"
          },
          "title": "Fields Extracted",
          "type": "array"
        },
        "method": {
          "$ref": "#/$defs/ExtractionMethod"
        },
        "pass_number": {
          "title": "Pass Number",
          "type": "integer"
        },
        "prompt_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Version"
        }
      },
      "required": [
        "pass_number",
        "method"
      ],
      "title": "ProvenancePass",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Result from multi-pass extraction synthesis.",
  "properties": {
    "all_citations": {
      "items": {
        "$ref": "#/$defs/Citation"
      },
      "title": "All Citations",
      "type": "array"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "discrepancies": {
      "items": {
        "$ref": "#/$defs/FieldDiscrepancy"
      },
      "title": "Discrepancies",
      "type": "array"
    },
    "document_id": {
      "title": "Document Id",
      "type": "string"
    },
    "final_fields": {
      "items": {
        "$ref": "#/$defs/CitedField"
      },
      "title": "Final Fields",
      "type": "array"
    },
    "passes": {
      "items": {
        "$ref": "#/$defs/ProvenancePass"
      },
      "title": "Passes",
      "type": "array"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "source_doc_hash": {
      "title": "Source Doc Hash",
      "type": "string"
    }
  },
  "required": [
    "document_id",
    "source_doc_hash",
    "final_fields",
    "confidence",
    "provenance"
  ],
  "title": "SynthesisResult",
  "type": "object"
}
